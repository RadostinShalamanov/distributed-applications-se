@using E_Commerce.FrontEnd.Models.Common
@using E_Commerce.FrontEnd.Models.Orders
@using E_Commerce.FrontEnd.Helpers
@inject IHttpContextAccessor httpContextAccessor
@model PagedResponse<OrderResponseModel>


@{
    ViewData["Title"] = "Orders";
    // Check if the user is an admin
    var sessionToken = httpContextAccessor.HttpContext?.Session.GetString("JWToken");
    var isAuthenticated = !string.IsNullOrEmpty(sessionToken);
    var isAdmin = httpContextAccessor.HttpContext?.IsAdmin() == true;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>@(isAdmin ? "Manage All Orders" : "My Order History")</h2>

        @if (isAuthenticated && !isAdmin)
        {
            <a asp-action="Create" class="btn btn-success shadow-sm">
                Place New Order
            </a>
        }
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Status</label>
                    <select name="status" class="form-select">
                        <option value="">All Statuses</option>
                        <option value="Pending" selected="@(ViewBag.Status == "Pending")">Pending</option>
                        <option value="Processing" selected="@(ViewBag.Status == "Processing")">Processing</option>
                        <option value="Shipped" selected="@(ViewBag.Status == "Shipped")">Shipped</option>
                        <option value="Delivered" selected="@(ViewBag.Status == "Delivered")">Delivered</option>
                        <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Cancelled</option>
                    </select>
                </div>

                @* SECURITY: Only show UserID filter to Admins *@
                @if (isAdmin)
                {
                    <div class="col-md-2">
                        <label class="form-label small fw-bold">User ID</label>
                        <input type="number" name="userId" value="@ViewBag.UserId" class="form-control" placeholder="Search ID..." />
                    </div>
                }

                <div class="col-md-2">
                    <label class="form-label small fw-bold">Payment</label>
                    <select name="isPaid" class="form-select">
                        <option value="">All</option>
                        <option value="true" selected="@(ViewBag.IsPaid == true)">Paid Only</option>
                        <option value="false" selected="@(ViewBag.IsPaid == false)">Unpaid Only</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label small fw-bold">Sort By</label>
                    <select name="sortBy" class="form-select">
                        <option value="">Default</option>
                        <option value="date" selected="@(ViewBag.SortBy == "date")">Date</option>
                        <option value="totalprice" selected="@(ViewBag.SortBy == "totalprice")">Total Price</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label small fw-bold">Direction</label>
                    <select name="descending" class="form-select">
                        <option value="false" selected="@(ViewBag.Descending == false)">Ascending</option>
                        <option value="true" selected="@(ViewBag.Descending == true)">Descending</option>
                    </select>
                </div>

                <div class="col-md-1">
                    <button type="submit" class="btn btn-primary w-100">Filter</button>
                </div>
            </form>
        </div>
    </div>

    <table class="table table-striped table-hover align-middle border shadow-sm">
        <thead class="table-dark">
            <tr>
                <th style="width: 80px;">Id</th>
                <th>Date</th>
                <th>Status</th>
                <th>Total</th>
                <th>Payment</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model?.Items != null && Model.Items.Any())
            {
                @foreach (var order in Model.Items)
                {
                    <tr>
                        <td class="fw-bold">#@order.Id</td>
                        <td>@order.OrderDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td>
                            <span class="badge @(order.Status switch {
                                "Delivered" => "bg-success",
                                "Pending" => "bg-warning text-dark",
                                "Cancelled" => "bg-danger",
                                _ => "bg-secondary"
                            })">@order.Status</span>
                        </td>
                        <td class="fw-bold">@String.Format("{0:C}", order.TotalPrice)</td>
                        <td>
                            @if (order.IsPaid)
                            {
                                <span class="badge rounded-pill bg-light text-success border border-success">Paid</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-light text-danger border border-danger">Unpaid</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-info text-white">Details</a>

                            @if (!order.IsPaid && !isAdmin)
                            {
                               <a asp-action="Pay" asp-route-id="@order.Id" class="btn btn-sm btn-success">
                                   Pay Now
                               </a>
                            }
                            @if (isAdmin)
                            {
                                <a asp-action="Edit" asp-route-id="@order.Id" class="btn btn-sm btn-warning">Edit</a>
                                <form method="post" asp-action="Delete" asp-route-id="@order.Id" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Confirm deletion of Order #@order.Id?')">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="6" class="text-center py-4 text-muted">No orders match your criteria.</td></tr>
            }
        </tbody>
    </table>

    @if (Model != null && Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i"
                           asp-route-status="@ViewBag.Status"
                           asp-route-userId="@(isAdmin ? ViewBag.UserId : null)"
                           asp-route-isPaid="@ViewBag.IsPaid"
                           asp-route-sortBy="@ViewBag.SortBy"
                           asp-route-descending="@ViewBag.Descending">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }

    <div class="text-center mt-3">
        <small class="text-muted">Displaying @(Model?.Items?.Count() ?? 0) of @Model?.TotalItems results</small>
    </div>
</div>