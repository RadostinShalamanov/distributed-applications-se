@using E_Commerce.FrontEnd.Models.Orders
@model OrderResponseModel

@{
    ViewData["Title"] = $"Order #{Model.Id}";
}

<div class="container my-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-5 mb-4">Order #@Model.Id</h1>
        </div>
    </div>

    <!-- Order Summary Cards -->
    <div class="row mb-5">
        <div class="col-md-3 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title text-muted mb-2">Order Date</h6>
                    <p class="card-text fs-5">@Model.OrderDate.ToString("MMM dd, yyyy")</p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title text-muted mb-2">Status</h6>
                    <p class="card-text">
                        @{
                            var statusClass = Model.Status switch
                            {
                                "Completed" => "success",
                                "Pending" => "warning",
                                "Cancelled" => "danger",
                                _ => "secondary"
                            };
                        }
                        <span class="badge bg-@statusClass fs-6">@Model.Status</span>
                    </p>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card h-100">
                <div class="card-body">
                    <h6 class="card-title text-muted mb-2">Total Amount</h6>
                    <p class="card-text fs-5 fw-bold text-success">$@Model.TotalPrice</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Order Items Table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Order Items</h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.Items != null && Model.Items.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Product</th>
                                        <th class="text-center">Quantity</th>
                                        <th class="text-end">Price</th>
                                        <th class="text-end">Subtotal</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            <td class="align-middle">@item.ProductName</td>
                                            <td class="text-center align-middle">@item.Quantity</td>
                                            <td class="text-end align-middle">@item.Price.ToString("C")</td>
                                            <td class="text-end align-middle fw-bold">$@(item.Price* item.Quantity)</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">
                            <p>No items in this order.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="row mt-4">
        <div class="col-12">
            <a href="javascript:history.back()" class="btn btn-secondary">Back to Orders</a>
            <a href="@Url.Action("Index", "Orders")" class="btn btn-primary">View All Orders</a>
        </div>
    </div>
</div>
