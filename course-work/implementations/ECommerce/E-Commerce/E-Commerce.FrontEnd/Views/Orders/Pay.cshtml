@model E_Commerce.FrontEnd.Models.Orders.OrderResponseModel

@{
    ViewData["Title"] = "Checkout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0 text-center"><i class="bi bi-credit-card"></i> Payment Checkout</h4>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <div class="text-center mb-4">
                        <h6 class="text-muted text-uppercase small">Order Number</h6>
                        <h3 class="fw-bold">#@Model.Id</h3>
                    </div>

                    <div class="bg-light p-3 rounded mb-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Order Date:</span>
                            <span class="fw-bold">@Model.OrderDate.ToShortDateString()</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span>Items Count:</span>
                            <span class="fw-bold">@Model.Items.Count</span>
                        </div>
                        <div class="d-flex justify-content-between border-top pt-2 mt-2">
                            <span class="h5">Total to Pay:</span>
                            <span class="h5 text-primary fw-bold">@Model.TotalPrice.ToString("C")</span>
                        </div>
                    </div>

                    <form asp-action="Pay" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="amount" value="@Model.TotalPrice" />

                        <div class="mb-4">
                            <label class="form-label fw-bold">Select Payment Method</label>
                            <div class="form-check border p-3 rounded mb-2">
                                <input class="form-check-input ms-1" type="radio" name="method" id="card" checked>
                                <label class="form-check-label ms-2" for="card">
                                    Debit/Credit Card <span class="text-muted small">(Simulated)</span>
                                </label>
                            </div>
                            <div class="form-check border p-3 rounded">
                                <input class="form-check-input ms-1" type="radio" name="method" id="wallet">
                                <label class="form-check-label ms-2" for="wallet">
                                    Digital Wallet / Crypto
                                </label>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg shadow-sm">
                                Confirm Payment
                            </button>
                            <a asp-action="Index" class="btn btn-link text-muted">Cancel and go back</a>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-white text-center py-3">
                    <small class="text-muted"><i class="bi bi-lock-fill"></i> Secure Encrypted Transaction</small>
                </div>
            </div>
        </div>
    </div>
</div>