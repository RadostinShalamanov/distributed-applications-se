@using E_Commerce.FrontEnd.Helpers
@inject IHttpContextAccessor httpContextAccessor

@{
    ViewData["Title"] = "Home Page";
    var isLoggedIn = httpContextAccessor.HttpContext?.Session.GetString("JWToken") != null;
    var isAdmin = httpContextAccessor.HttpContext?.IsAdmin() == true;
    var username = httpContextAccessor.HttpContext?.GetUsername();

    // Dynamically calculate column width: 4 columns for Admin (col-lg-3), 3 columns for Customers (col-lg-4)
    var colClass = (isLoggedIn && isAdmin) ? "col-lg-3" : "col-lg-4";
}

<link rel="stylesheet" href="~/css/custom-theme.css" />

<div class="header-gradient text-white py-5 mb-5 rounded">
    <div class="container p-4">
        <h1 class="display-4 fw-bold mb-0">Welcome to PlovdivBuy</h1>
        @if (isLoggedIn)
        {
            <p class="display-8 fst-italic mt-2 mb-0">
                Hello, <strong>@username</strong>!
            </p>
        }
    </div>
</div>

<div class="container">
    <div class="row g-4 mb-5 justify-content-center">

        <div class="col-md-6 @colClass">
            <div class="card card-accent h-100 shadow-sm">
                <div class="card-body p-4 d-flex flex-column">
                    <h4 class="card-title mb-3 fw-bold">Products</h4>
                    <p class="card-text flex-grow-1 fs-5">Browse and manage products in your catalog.</p>
                    <a class="btn btn-accent align-self-start mt-auto" asp-controller="Products" asp-action="Index">Products</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 @colClass">
            <div class="card card-accent h-100 shadow-sm">
                <div class="card-body p-4 d-flex flex-column">
                    <h4 class="card-title mb-3 fw-bold">Orders</h4>
                    <p class="card-text flex-grow-1 fs-5">View recent orders and update order status.</p>
                    <a class="btn btn-accent align-self-start mt-auto" asp-controller="Orders" asp-action="Index">Orders</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 @colClass">
            <div class="card card-accent h-100 shadow-sm">
                <div class="card-body p-4 d-flex flex-column">
                    <h4 class="card-title mb-3 fw-bold">Categories</h4>
                    <p class="card-text flex-grow-1 fs-5">Organize products into categories and add new ones.</p>
                    <a class="btn btn-accent align-self-start mt-auto" asp-controller="Categories" asp-action="Index">Categories</a>
                </div>
            </div>
        </div>

        @if (isLoggedIn && isAdmin)
        {
            <div class="col-md-6 @colClass">
                <div class="card card-accent h-100 shadow-sm">
                    <div class="card-body p-4 d-flex flex-column">
                        <h4 class="card-title mb-3 fw-bold">Users</h4>
                        <p class="card-text flex-grow-1 fs-5">Manage customer and admin user accounts.</p>
                        <a class="btn btn-accent align-self-start mt-auto" asp-controller="Users" asp-action="Index">Users</a>
                    </div>
                </div>
            </div>
        }

    </div>
</div>